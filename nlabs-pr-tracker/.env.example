# ─── Copy this file to .env and fill in your real values ───────────────────
# Never commit .env to Git.

# A random secret you generate (min 32 chars).
# Same value must be added to GitHub repo as:  Settings → Secrets → NLABS_WEBHOOK_SECRET
NLABS_WEBHOOK_SECRET=replace_with_a_long_random_secret_min_32_chars

# Your Notion Internal Integration Secret
# notion.so/my-integrations → N-Labs Make Automation → show secret
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The 32-char ID of your Fellow Tracker database in Notion
# Get it from the database URL: notion.so/workspace/<THIS_PART>?v=...
NOTION_FELLOW_TRACKER_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The full public URL where this server is deployed
# Example (Railway): https://nlabs-pr-tracker-production.up.railway.app
# This value must also be added to GitHub repo as: Settings → Secrets → NLABS_ENDPOINT_URL
NLABS_ENDPOINT_URL=https://your-deployment-url.railway.app
